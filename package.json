{
  "name": "rpgmtrans-compiler",
  "version": "0.1.0",
  "type": "module",
  "description": "Local runtime translation bridge and pretranslation cache tool for desktop RPG/VN games.",
  "bin": {
    "rpgmtrans": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "desktop:build": "dotnet build desktop/RPGMTransLauncher/RPGMTransLauncher.csproj -c Release",
    "desktop:run": "dotnet run --project desktop/RPGMTransLauncher/RPGMTransLauncher.csproj",
    "desktop:publish": "node scripts/publish.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
