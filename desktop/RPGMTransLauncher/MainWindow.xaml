<Window
    x:Class="RPGMTransLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RPGMTransCompiler 本地运行时翻译启动器">

        <Grid x:Name="RootGrid"
          AllowDrop="True"
          RequestedTheme="Dark"
          Padding="16"
          RowSpacing="12"
          Background="#0B1118"
          DragEnter="RootGrid_DragOver"
          DragLeave="RootGrid_DragLeave"
          DragOver="RootGrid_DragOver"
          Drop="RootGrid_Drop">
        <Grid.Resources>
            <SolidColorBrush x:Key="PanelBrush" Color="#111923" />
            <SolidColorBrush x:Key="PanelAltBrush" Color="#141F2B" />
            <SolidColorBrush x:Key="FieldBrush" Color="#0C1219" />
            <SolidColorBrush x:Key="BorderBrushSoft" Color="#26384C" />
            <SolidColorBrush x:Key="BorderBrushStrong" Color="#36516E" />
            <SolidColorBrush x:Key="TextBrush" Color="#E8EEF7" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#A8B6C8" />
            <SolidColorBrush x:Key="ActionBrush" Color="#1D2A38" />
            <SolidColorBrush x:Key="BannerBrush" Color="#152235" />
            <SolidColorBrush x:Key="BannerBorderBrush" Color="#4F7094" />

            <SolidColorBrush x:Key="TextControlBackground" Color="#0C1219" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0F1822" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#101A25" />
            <SolidColorBrush x:Key="TextControlForeground" Color="#E8EEF7" />
            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#E8EEF7" />
            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#F3F7FC" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#36516E" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#4F7094" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#3D8BFF" />
            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#7E8EA3" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#7E8EA3" />
            <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#2F6FBC" />

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,5" />
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,5" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ActionBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,6" />
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
        </Grid.Resources>

        <Grid x:Name="MainPage" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="DropTarget"
                    Grid.Row="0"
                    MinHeight="152"
                    Padding="18"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Tapped="DropTarget_Tapped">
                <Grid RowSpacing="10" IsHitTestVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="拖入游戏启动程序 exe，或点击选择要注入的游戏"
                               TextAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="支持：RPG Maker MV/MZ/XP/VX/VX Ace、Ren'Py、TyranoScript/TyranoBuilder"
                               TextAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Grid.Row="2"
                               Text="不支持：浏览器/移动导出版、RPG Maker 2000/2003"
                               TextAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="WrapWholeWords" />
                    <Grid x:Name="ProjectSummaryGrid"
                          Grid.Row="3"
                          Margin="0,8,0,0"
                          RowSpacing="6"
                          ColumnSpacing="12"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="游戏路径" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="GamePathText" Grid.Row="0" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="修改文件" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="InjectPathText" Grid.Row="1" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="项目库" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="DbPathText" Grid.Row="2" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid RowSpacing="8" ColumnSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="136" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="目标语言" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                    <ComboBox x:Name="TargetLangBox" Grid.Row="0" Grid.Column="1" MinHeight="34" SelectionChanged="TargetLangBox_SelectionChanged" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="模型源" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                    <ComboBox x:Name="ModelSourceBox" Grid.Row="0" Grid.Column="3" MinHeight="34" SelectionChanged="ModelSourceBox_SelectionChanged" />
                    <Button Grid.Row="0" Grid.Column="4" Content="配置模型源" MinWidth="128" MinHeight="34" Click="OpenConfigPage_Click" />

                    <CheckBox x:Name="SkipTranslatedBox"
                              Grid.Row="1"
                              Grid.Column="4"
                              Grid.ColumnSpan="2"
                              Content="跳过已翻译条目"
                              VerticalAlignment="Center"
                              Checked="SkipTranslatedBox_Changed"
                              Unchecked="SkipTranslatedBox_Changed" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="当前配置" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="ModelSourceSummaryText"
                               Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="3"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ToggleRuntimeButton" Content="未注入，点击注入" MinWidth="144" MinHeight="36" Click="ToggleRuntimeButton_Click" />
                        <Button x:Name="ToggleWatchButton" Content="未监听，点击监听" MinWidth="144" MinHeight="36" Click="ToggleWatchButton_Click" />
                        <Button x:Name="PretranslateButton" Content="离线批量翻译" MinWidth="128" MinHeight="36" Click="PretranslateButton_Click" />
                        <Button x:Name="LaunchGameButton" Content="启动游戏" MinWidth="96" MinHeight="36" Click="LaunchGameButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="LogPanel"
                    Grid.Row="3"
                    Background="#0D141D"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1">
                <Grid Background="#0D141D">
                    <ScrollViewer x:Name="LogScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Enabled"
                                  ZoomMode="Disabled">
                        <TextBlock x:Name="LogTextBlock"
                                   Padding="10"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   Foreground="#DCE6F2"
                                   TextWrapping="NoWrap"
                                   IsTextSelectionEnabled="False" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Row="4" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.38*" />
                    <ColumnDefinition Width="0.62*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="StatsText" Grid.Column="1" VerticalAlignment="Center" TextAlignment="Right" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Grid>

        <Grid x:Name="ConfigPage"
              Visibility="Collapsed"
              RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="模型源配置" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="返回" MinHeight="36" Click="BackToMainPage_Click" />
            </Grid>

            <Border Grid.Row="1"
                    Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ListView x:Name="ModelSourceList"
                              Grid.Column="0"
                              Background="{StaticResource FieldBrush}"
                              BorderBrush="{StaticResource BorderBrushStrong}"
                              BorderThickness="1"
                              SelectionChanged="ModelSourceList_SelectionChanged" />

                    <Grid Grid.Column="1" RowSpacing="10" ColumnSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBox x:Name="ConfigNameBox" Grid.Row="0" Grid.Column="1" MinHeight="34" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="格式" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <ComboBox x:Name="ConfigFormatBox" Grid.Row="1" Grid.Column="1" MinHeight="34" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API Base" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBox x:Name="ConfigBaseUrlBox" Grid.Row="2" Grid.Column="1" MinHeight="34" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="模型" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <Grid Grid.Row="3" Grid.Column="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                            </Grid.ColumnDefinitions>
                            <AutoSuggestBox x:Name="ConfigModelBox"
                                            Grid.Column="0"
                                            MinHeight="34"
                                            PlaceholderText="手动输入，或点击右侧获取模型"
                                            TextChanged="ConfigModelBox_TextChanged"
                                            SuggestionChosen="ConfigModelBox_SuggestionChosen"
                                            QuerySubmitted="ConfigModelBox_QuerySubmitted" />
                            <Button x:Name="FetchModelsButton"
                                    Grid.Column="1"
                                    Content="获取模型"
                                    MinHeight="34"
                                    Click="FetchModelsButton_Click" />
                        </Grid>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <Grid Grid.Row="4" Grid.Column="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <PasswordBox x:Name="ConfigApiKeyPasswordBox" MinHeight="34" PasswordChanged="ConfigApiKeyPasswordBox_PasswordChanged" />
                                <TextBox x:Name="ConfigApiKeyTextBox" MinHeight="34" Visibility="Collapsed" TextChanged="ConfigApiKeyTextBox_TextChanged" />
                            </Grid>
                            <CheckBox x:Name="ConfigShowKeyBox" Grid.Column="1" Content="显示密钥" VerticalAlignment="Center" Checked="ConfigShowKeyBox_Changed" Unchecked="ConfigShowKeyBox_Changed" />
                        </Grid>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="输入价/百万token" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBox x:Name="ConfigInputPriceBox" Grid.Row="5" Grid.Column="1" MinHeight="34" PlaceholderText="0" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="输出价/百万token" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBox x:Name="ConfigOutputPriceBox" Grid.Row="6" Grid.Column="1" MinHeight="34" PlaceholderText="0" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="新增" MinWidth="96" MinHeight="36" Click="AddModelSource_Click" />
                <Button Content="删除" MinWidth="96" MinHeight="36" Click="DeleteModelSource_Click" />
                <Button Content="保存配置" MinWidth="120" MinHeight="36" Click="SaveModelSource_Click" />
            </StackPanel>
        </Grid>

        <Border x:Name="BannerHost"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                Margin="8"
                Padding="12"
                Background="{StaticResource BannerBrush}"
                BorderBrush="{StaticResource BannerBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Name="BannerTitleText" FontSize="15" FontWeight="SemiBold" />
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="BannerMessageText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="WrapWholeWords"
                                   IsTextSelectionEnabled="True" />
                    </ScrollViewer>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                    <Button x:Name="BannerPrimaryButton" MinWidth="88" MinHeight="32" Visibility="Collapsed" Click="BannerPrimaryButton_Click" />
                    <Button x:Name="BannerSecondaryButton" MinWidth="88" MinHeight="32" Visibility="Collapsed" Click="BannerSecondaryButton_Click" />
                    <Button x:Name="BannerCloseButton" Content="关闭" MinWidth="72" MinHeight="32" Click="BannerCloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="DragOverlayHost"
              Visibility="Collapsed"
              Background="#CC07111B"
              IsHitTestVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="DragScanZone"
                    Grid.Column="0"
                    Margin="18"
                    Padding="24"
                    Background="#223A5168"
                    BorderBrush="#5E8AB7"
                    BorderThickness="2"
                    CornerRadius="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="导入并扫描游戏" FontSize="26" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock Text="只识别引擎、生成项目库和路径摘要" Foreground="{StaticResource MutedTextBrush}" FontSize="15" TextAlignment="Center" />
                </StackPanel>
            </Border>
            <Border x:Name="DragAutoZone"
                    Grid.Column="1"
                    Margin="18"
                    Padding="24"
                    Background="#223A5168"
                    BorderBrush="#5E8AB7"
                    BorderThickness="2"
                    CornerRadius="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="导入并自动注入监听并启动游戏" FontSize="26" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock Text="识别后自动注入插件、启动监听和游戏" Foreground="{StaticResource MutedTextBrush}" FontSize="15" TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
